{
  "name": "backend",
  "version": "1.0.0",
  "description": "REST API for customer support tickets with bulk import and auto-classification",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts",
    "test": "node --no-warnings --experimental-vm-modules ../node_modules/jest/bin/jest.js --runInBand",
    "test:coverage": "node --no-warnings --experimental-vm-modules ../node_modules/jest/bin/jest.js --coverage --runInBand"
  },
  "keywords": [
    "support",
    "tickets",
    "api",
    "fastify",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
